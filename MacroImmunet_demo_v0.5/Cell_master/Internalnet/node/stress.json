{
  "node_id": "stress",

  "_meta": {
    "description": "Cellular stress level",
    "consumed_by": ["HIR", "PassiveEngine", "StateUpdate"]
  },
  "writable_by": ["behavior", "passive", "external"],
  "functional_group": {
    "value": "stress"
  },

  "structural_type": {
    "value": "internal"
  },

  "external_key": {
    "value": null
  },
  "exposed_to_scan": {
    "value": false
  },

  "passive_readable": {
    "value": true
  },

  "hir_role": {
    "value": "input"
  },

  "readable_by": ["passive", "behavior", "HIR"],

  "base_value": {
    "value": 0.1
  },

  "update_rule": {
    "type": "weighted_sum"
  },

  "state_dynamics": {
    "type": "accumulative",
    "decay": 0.9,
    "update_sources": ["passive", "behavior"]
  },

  "decay": {
    "enabled": true,
    "tau": 10.0,
    "mode": "exponential"
  },

  "clamp": {
    "enabled": true,
    "min": 0.0,
    "max": 1.0
  }
}
