{
  "node_id": "resources",

  "_meta": {
    "description": "Generic cellular resources (amino acids, lipids, etc.)",
    "consumed_by": ["BehaviorEngine", "StateUpdate"]
  },
  "writable_by": ["external"],
  "semantic_type": {
    "value": "substance"
  },

  "functional_group": {
    "value": "metabolism"
  },

  "structural_type": {
    "value": "internal"
  },
  "external_key": {
    "value": null
  },

  "exposed_to_scan": {
    "value": false
  },

  "passive_readable": {
    "value": true
  },

  "hir_role": {
    "value": "modulator"
  },

  "readable_by": ["behavior"],

  "base_value": {
    "value": 0.5
  },
  "update_rule": {
    "type": "weighted_sum"
  },

  "state_dynamics": {
    "type": "accumulative",
    "decay": 0.9,
    "update_sources": ["behavior"]
  },

  "clamp": {
    "enabled": true,
    "min": 0.0,
    "max": 1.0
  }
